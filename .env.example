DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
BOT_PREFIX=!
PURGE_CHANNEL_IDS=

# Logging (ERROR, WARN, INFO, DEBUG — default: INFO)
LOG_LEVEL=INFO

# XP / Leveling System
XP_COOLDOWN_SECONDS=60
XP_MIN=15
XP_MAX=25
LEVELUP_CHANNEL_ID=

# Ollama Chat (AI responses when bot is mentioned)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral-nemo:12b
OLLAMA_CONTEXT_MESSAGES=10

# Shadowrun Campaign System
CAMPAIGN_CHANNEL_ID=
OLLAMA_GM_TIMEOUT_MS=120000

# Weather System
WEATHER_CHANNEL_ID=
WEATHER_LOCATION=
WEATHER_DAILY_TIME=07:00
WEATHERAPI_KEY=
WEATHER_ALERT_INTERVAL_MS=300000

# Translation (DeepL is optional — Ollama is used as primary translator)
DEEPL_API_KEY=

# Vocabulary (Word of the Day)
VOCAB_CHANNEL_ID=
VOCAB_DAILY_TIME=08:00
VOCAB_DEFAULT_LANGUAGE=ES

# Bot Announce (channel where the bot posts when it comes online)
ANNOUNCE_CHANNEL_ID=

# Music Club (weekly song sharing and rating)
MUSIC_CLUB_CHANNEL_ID=
MUSIC_CLUB_ROUND_DAY=1
MUSIC_CLUB_ROUND_TIME=10:00
MUSIC_CLUB_SUBMISSION_DAYS=2
MUSIC_CLUB_RATING_DAYS=2

# Google API key (used for YouTube Data API and Google Books cover/metadata fallback)
GOOGLE_API_KEY=

# Recipe Book (scans channel for recipes, stores them in DB)
RECIPE_CHANNEL_ID=

# Link Decrapifier (cleans tracking params from URLs; empty = all channels)
CLEAN_LINKS_CHANNEL_IDS=

# Community Library (share and borrow books)
LIBRARY_CHANNEL_ID=
LIBRARY_DEFAULT_LOAN_DAYS=14

# Birthday Tracking (passive detection + daily announcements)
BIRTHDAY_CHANNEL_ID=
BIRTHDAY_CHECK_TIME=08:00

# Auto-deploy webhook (for production server)
DEPLOY_WEBHOOK_PORT=9000
DEPLOY_WEBHOOK_SECRET=
PM2_BOT_NAME=discord-bot
